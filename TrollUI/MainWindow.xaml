<Window x:Class="TrollUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Windows Service" Height="450" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid>
        <!-- SkiaSharp Canvas en arriere plan pour les effets -->
        <skia:SKElement x:Name="skCanvas" PaintSurface="OnPaintSurface" IgnorePixelScaling="True" />
        
        <!-- Panel de sélection du jeu (par dessus le Skia, visible au démarrage) -->
        <Grid x:Name="gamePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid.Resources>
                <!-- Animation de pulsation infinie -->
                <Storyboard x:Key="PulseAnim" RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1.0" To="1.15" Duration="0:0:0.4" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1.0" To="1.15" Duration="0:0:0.4" />
                </Storyboard>
                <Storyboard x:Key="JitterAnim" RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1.2" Duration="0:0:0.1" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1.2" Duration="0:0:0.1" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="-5" To="5" Duration="0:0:0.05" />
                </Storyboard>
            </Grid.Resources>
            
            <!-- Titre / Avertissement Goofy -->
            <Border Grid.Row="0" Background="#FFFF00FF" BorderBrush="#FF00FF00" BorderThickness="8" CornerRadius="50" Padding="40,30" MaxWidth="1000">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <RotateTransform Angle="-3"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource PulseAnim}"/>
                    </EventTrigger>
                </Border.Triggers>
                <TextBlock Text="⚠ OMG TON PC EST POSSÉDÉ UWU !! Si tu essayes de le fermer je formate ton SSD hihi. Choisis ta mort !! (*^ω^*)" 
                           Foreground="#FFFFFF00" FontSize="32" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"
                           FontFamily="Comic Sans MS">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="3"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Border>
            
            <!-- Question Goofy -->
            <Border Grid.Row="2" Background="#FF00FFFF" BorderBrush="#FFFA8072" BorderThickness="5" CornerRadius="100" Padding="40,20">
                <TextBlock Text="👉 LA MIGNONNERIE OU L'ENFER ??? 👈" 
                           Foreground="#FFFF1493" FontSize="48" FontWeight="ExtraBold" TextAlignment="Center"
                           FontFamily="Comic Sans MS"/>
            </Border>
            
            <!-- Boutons Absurdes Multi-Choix (GitHub Ready) -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 20, 0, 0">
                <!-- Bouton RIRIMIAOU (CRESCENDO) -->
                <Border x:Name="btnRiri" Background="#FF32CD32" BorderBrush="#FFFFD700" BorderThickness="6" CornerRadius="30" Padding="0" Margin="10,0"
                        Cursor="Hand" MouseLeftButtonDown="BtnRiri_Click">
                    <Border.RenderTransform>
                        <TransformGroup><ScaleTransform ScaleX="1" ScaleY="1" /><RotateTransform Angle="-3"/></TransformGroup>
                    </Border.RenderTransform>
                    <Border.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard Storyboard="{StaticResource PulseAnim}"/></EventTrigger></Border.Triggers>
                    <Border.Effect><DropShadowEffect Color="#FFFF00FF" BlurRadius="30" ShadowDepth="5"/></Border.Effect>
                    <TextBlock Text="🐱 RIRIMIAOU" Foreground="#FF00008B" FontSize="28" FontWeight="Bold" Padding="20,15" FontFamily="Comic Sans MS"/>
                </Border>
                
                <!-- Bouton PUNISHER (EXTRÊME) -->
                <Border x:Name="btnPunisher" Background="#FFFF0000" BorderBrush="#FF000000" BorderThickness="8" CornerRadius="0" Padding="0" Margin="10,0"
                        Cursor="Hand" MouseLeftButtonDown="BtnPunisher_Click">
                    <Border.RenderTransform>
                        <TransformGroup><ScaleTransform ScaleX="1" ScaleY="1" /><RotateTransform Angle="3"/></TransformGroup>
                    </Border.RenderTransform>
                    <Border.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard Storyboard="{StaticResource JitterAnim}"/></EventTrigger></Border.Triggers>
                    <Border.Effect><DropShadowEffect Color="#FF00FF00" BlurRadius="50" ShadowDepth="-5"/></Border.Effect>
                    <TextBlock Text="💀 PUNISHER" Foreground="#FFFFFF" FontSize="30" FontWeight="ExtraBold" Padding="20,15" FontFamily="Impact"/>
                </Border>
                
                <!-- NOUVEAU: Bouton SOFT (INSULTES DOUCES) -->
                <Border x:Name="btnSoft" Background="#FFFFA500" BorderBrush="#FF4B0082" BorderThickness="6" CornerRadius="15" Padding="0" Margin="10,0"
                        Cursor="Hand" MouseLeftButtonDown="BtnSoft_Click">
                    <Border.RenderTransform>
                        <TransformGroup><ScaleTransform ScaleX="1" ScaleY="1" /><RotateTransform Angle="-2"/></TransformGroup>
                    </Border.RenderTransform>
                    <Border.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard Storyboard="{StaticResource PulseAnim}"/></EventTrigger></Border.Triggers>
                    <Border.Effect><DropShadowEffect Color="#FF4B0082" BlurRadius="20" ShadowDepth="5"/></Border.Effect>
                    <TextBlock Text="🤡 SOFT / JOKES" Foreground="#FF4B0082" FontSize="26" FontWeight="Bold" Padding="20,15" FontFamily="Comic Sans MS"/>
                </Border>
                
                <!-- NOUVEAU: Bouton DEBUG (VOIR LES SVGs) -->
                <Border x:Name="btnDebug" Background="#FF483D8B" BorderBrush="#FF00FFFF" BorderThickness="4" CornerRadius="5" Padding="0" Margin="10,0"
                        Cursor="Hand" MouseLeftButtonDown="BtnDebug_Click">
                    <Border.RenderTransform>
                        <TransformGroup><ScaleTransform ScaleX="1" ScaleY="1" /><RotateTransform Angle="0"/></TransformGroup>
                    </Border.RenderTransform>
                    <Border.Effect><DropShadowEffect Color="#FF00FFFF" BlurRadius="15" ShadowDepth="0"/></Border.Effect>
                    <TextBlock Text="⚙️ DEBUG SVGs" Foreground="#FF00FFFF" FontSize="24" FontWeight="Normal" Padding="20,15" FontFamily="Consolas"/>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
